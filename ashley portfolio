<style>
:root{
  --green:#4CAF50;--green-light:#66BB6A;--green-dim:#2E7D32;
  --white:#F4F4F0;--gray-light:#A8A8A4;--gray-mid:#555552;--gray-dark:#252523;
  --black:#0C0C0B;--bg:#0E0E0D;--card:#161614;--border:rgba(76,175,80,0.15);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--white);font-family:'Syne',sans-serif;font-size:16px;line-height:1.7;overflow-x:hidden;}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;justify-content:space-between;align-items:center;padding:1.1rem 5%;background:rgba(14,14,13,0.93);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);}
.nav-logo{font-family:'Space Mono',monospace;font-weight:700;font-size:0.8rem;color:var(--green);letter-spacing:0.12em;text-decoration:none;flex-shrink:0;}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{font-family:'Space Mono',monospace;font-size:0.68rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--gray-light);text-decoration:none;transition:color 0.2s;padding:0.25rem 0;}
.nav-links a:hover{color:var(--green);}

/* Hamburger */
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:300;}
.hamburger span{display:block;width:24px;height:2px;background:var(--white);transition:transform 0.3s,opacity 0.3s;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

/* Mobile nav drawer */
.mobile-nav{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(14,14,13,0.98);z-index:150;flex-direction:column;align-items:center;justify-content:center;gap:2.5rem;}
.mobile-nav.open{display:flex;}
.mobile-nav a{font-family:'Space Mono',monospace;font-size:1.1rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--white);text-decoration:none;transition:color 0.2s;}
.mobile-nav a:hover{color:var(--green);}

/* ── HERO ── */
#hero{min-height:100vh;display:flex;align-items:center;padding:7rem 5% 4rem;}
.hero-left{max-width:700px;width:100%;}
.hero-tag{display:inline-flex;align-items:center;gap:0.5rem;font-family:'Space Mono',monospace;font-size:0.68rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--green);border:1px solid rgba(76,175,80,0.4);padding:0.35rem 1rem;margin-bottom:2rem;animation:fadeUp 0.6s ease both;}
.hero-tag::before{content:'';width:6px;height:6px;background:var(--green);border-radius:50%;animation:blink 2s infinite;flex-shrink:0;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.25;}}
.hero-name{font-size:clamp(2rem,4.5vw,3.8rem);font-weight:800;line-height:1.0;letter-spacing:-0.03em;margin-bottom:0.5rem;animation:fadeUp 0.6s 0.1s ease both;}
.hero-name span{color:var(--green);}
.hero-title{font-family:'Space Mono',monospace;font-size:clamp(0.72rem,1.5vw,0.85rem);color:var(--gray-light);letter-spacing:0.06em;margin-bottom:2rem;animation:fadeUp 0.6s 0.2s ease both;}
.hero-desc{font-size:clamp(0.88rem,1.5vw,0.96rem);color:var(--gray-light);line-height:1.85;margin-bottom:2.5rem;animation:fadeUp 0.6s 0.3s ease both;}
.hero-desc strong{color:var(--white);font-weight:700;}
.hero-cta{display:flex;gap:1rem;flex-wrap:wrap;animation:fadeUp 0.6s 0.4s ease both;}
.btn-primary{background:var(--green);color:var(--black);font-family:'Space Mono',monospace;font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:0.9rem 2rem;border:none;cursor:pointer;text-decoration:none;transition:opacity 0.2s,transform 0.2s;display:inline-block;white-space:nowrap;}
.btn-primary:hover{opacity:0.85;transform:translateY(-2px);}
.btn-primary:disabled{opacity:0.5;cursor:not-allowed;transform:none;}
.btn-outline{background:transparent;color:var(--white);font-family:'Space Mono',monospace;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.9rem 2rem;border:1px solid var(--gray-mid);cursor:pointer;text-decoration:none;transition:border-color 0.2s,color 0.2s;display:inline-block;white-space:nowrap;}
.btn-outline:hover{border-color:var(--green);color:var(--green);}
.hero-stats{display:flex;flex-wrap:wrap;gap:2rem;margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);animation:fadeUp 0.6s 0.5s ease both;}
.stat-num{font-weight:800;font-size:clamp(1.5rem,3vw,2rem);color:var(--green);line-height:1;}
.stat-label{font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--gray-mid);margin-top:0.25rem;}

/* ── SECTIONS ── */
section{padding:clamp(3rem,8vw,6rem) 5%;position:relative;z-index:1;}
.section-label{font-family:'Space Mono',monospace;font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--green);margin-bottom:0.75rem;}
.section-title{font-size:clamp(1.6rem,4vw,3rem);font-weight:800;line-height:1.05;letter-spacing:-0.02em;margin-bottom:clamp(2rem,5vw,3.5rem);}

/* ── SKILLS ── */
#skills{background:var(--card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(240px,100%),1fr));gap:1.25rem;}
.skill-card{background:var(--bg);border:1px solid var(--border);padding:1.5rem;position:relative;overflow:hidden;transition:border-color 0.25s;}
.skill-card:hover,.skill-card:focus-within{border-color:rgba(76,175,80,0.5);}
.skill-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--green);transform:scaleY(0);transform-origin:bottom;transition:transform 0.3s ease;}
.skill-card:hover::before{transform:scaleY(1);}
.skill-name{font-weight:700;font-size:1.05rem;margin-bottom:0.45rem;}
.skill-desc{font-size:0.85rem;color:var(--gray-light);line-height:1.65;margin-bottom:1rem;}
.skill-level{font-family:'Space Mono',monospace;font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;padding:0.22rem 0.65rem;border:1px solid;}
.skill-level.basic{color:var(--green-light);border-color:rgba(102,187,106,0.5);}
.skill-level.learning{color:var(--gray-light);border-color:var(--gray-mid);}

/* ── PROJECTS ── */
.projects-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(320px,100%),1fr));gap:2rem;}
.project-card{background:var(--card);border:1px solid var(--border);padding:clamp(1.5rem,4vw,2.5rem);position:relative;overflow:hidden;transition:transform 0.25s;}
.project-card:hover{transform:translateY(-4px);}
.project-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--green);transform:scaleX(0);transform-origin:left;transition:transform 0.35s ease;}
.project-card:hover::after{transform:scaleX(1);}
.project-num{font-family:'Space Mono',monospace;font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--green);margin-bottom:1rem;}
.project-title{font-size:clamp(1.2rem,3vw,1.5rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:1rem;line-height:1.1;}
.project-desc{font-size:0.9rem;color:var(--gray-light);line-height:1.8;margin-bottom:1.5rem;}
.project-tags{display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;}
.tag{font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--gray-light);background:rgba(255,255,255,0.04);border:1px solid var(--gray-dark);padding:0.25rem 0.65rem;}
.project-links{display:flex;gap:1rem;flex-wrap:wrap;}
.proj-link{font-family:'Space Mono',monospace;font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--green);text-decoration:none;transition:opacity 0.2s;}
.proj-link:hover{opacity:0.65;}
.status-badge{display:inline-block;font-family:'Space Mono',monospace;font-size:0.6rem;letter-spacing:0.14em;text-transform:uppercase;padding:0.22rem 0.65rem;margin-bottom:1.5rem;}
.status-badge.live{background:rgba(76,175,80,0.1);color:var(--green-light);border:1px solid rgba(76,175,80,0.4);}
.status-badge.wip{background:rgba(250,199,117,0.08);color:#FAC775;border:1px solid rgba(250,199,117,0.35);}

/* ── EDUCATION ── */
#education{background:var(--card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.timeline{position:relative;padding-left:2rem;}
.timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:1px;background:var(--border);}
.timeline-item{position:relative;padding-bottom:2.5rem;padding-left:1.5rem;}
.timeline-item:last-child{padding-bottom:0;}
.timeline-item::before{content:'';position:absolute;left:-2rem;top:8px;width:9px;height:9px;background:var(--green);transform:rotate(45deg);}
.timeline-year{font-family:'Space Mono',monospace;font-size:0.68rem;letter-spacing:0.14em;color:var(--green);margin-bottom:0.4rem;}
.timeline-degree{font-size:clamp(1rem,2.5vw,1.25rem);font-weight:700;margin-bottom:0.25rem;}
.timeline-school{font-family:'Space Mono',monospace;font-size:0.78rem;color:var(--gray-light);margin-bottom:0.75rem;}
.timeline-desc{font-size:0.88rem;color:var(--gray-mid);line-height:1.8;}

/* ── CONTACT ── */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;}
.contact-left h2{font-size:clamp(2rem,5vw,4rem);font-weight:800;line-height:0.95;letter-spacing:-0.03em;margin-bottom:1.5rem;}
.contact-left h2 span{color:var(--green);}
.contact-left p{font-size:0.93rem;color:var(--gray-light);margin-bottom:2rem;line-height:1.85;}
.contact-links{display:flex;flex-direction:column;gap:0.85rem;}
.contact-link{display:flex;align-items:center;gap:1rem;text-decoration:none;color:var(--white);padding:1rem 1.25rem;border:1px solid var(--border);background:var(--card);transition:border-color 0.25s,transform 0.2s;}
.contact-link:hover{border-color:rgba(76,175,80,0.5);transform:translateX(4px);}
.contact-link-icon{font-size:1rem;color:var(--green);flex-shrink:0;}
.contact-link-text strong{display:block;font-weight:700;font-size:0.88rem;}
.contact-link-text span{font-family:'Space Mono',monospace;font-size:0.68rem;color:var(--gray-light);word-break:break-all;}

/* ── CONTACT FORM ── */
.contact-form{display:flex;flex-direction:column;gap:1rem;}
.form-group{display:flex;flex-direction:column;gap:0.4rem;}
.form-group label{font-family:'Space Mono',monospace;font-size:0.65rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--gray-light);}
.form-group input,.form-group textarea{background:var(--card);border:1px solid var(--border);color:var(--white);font-family:'Syne',sans-serif;font-size:0.9rem;padding:0.85rem 1rem;outline:none;resize:vertical;transition:border-color 0.2s;width:100%;}
.form-group input:focus,.form-group textarea:focus{border-color:rgba(76,175,80,0.5);}
.form-group textarea{min-height:120px;}
.form-notice{font-family:'Space Mono',monospace;font-size:0.62rem;color:var(--gray-mid);letter-spacing:0.06em;}

/* Form feedback states */
.form-status{font-family:'Space Mono',monospace;font-size:0.7rem;letter-spacing:0.08em;padding:0.75rem 1rem;border:1px solid;display:none;}
.form-status.success{color:var(--green-light);border-color:rgba(76,175,80,0.4);background:rgba(76,175,80,0.08);}
.form-status.error{color:#FAC775;border-color:rgba(250,199,117,0.35);background:rgba(250,199,117,0.06);}
.form-status.show{display:block;}

/* ── FOOTER ── */
footer{padding:1.8rem 5%;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;}
.footer-left,.footer-right{font-family:'Space Mono',monospace;font-size:0.65rem;color:var(--gray-mid);}

@keyframes fadeUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:var(--green-dim);}

/* ════════════════════════════════
   RESPONSIVE BREAKPOINTS
════════════════════════════════ */

/* Tablet — ≤ 1024px */
@media(max-width:1024px){
  .contact-grid{gap:2.5rem;}
}

/* Small Tablet / Large Mobile — ≤ 768px */
@media(max-width:768px){
  .nav-links{display:none;}
  .hamburger{display:flex;}

  #hero{padding:6rem 5% 3rem;text-align:center;justify-content:center;}
  .hero-left{max-width:100%;}
  .hero-desc{max-width:100%;}
  .hero-cta{justify-content:center;}
  .hero-stats{justify-content:center;}

  .contact-grid{grid-template-columns:1fr;gap:2.5rem;}
  .projects-grid{grid-template-columns:1fr;}
  .skills-grid{grid-template-columns:repeat(auto-fill,minmax(min(200px,100%),1fr));}

  .timeline-item::before{left:-1.85rem;}
}

/* Mobile — ≤ 480px */
@media(max-width:480px){
  body{font-size:15px;}
  nav{padding:1rem 4%;}

  #hero{padding:5.5rem 4% 2.5rem;}
  .hero-name{font-size:clamp(1.8rem,8vw,2.6rem);}
  .hero-tag{font-size:0.62rem;}
  .hero-title{font-size:0.72rem;}
  .hero-cta{flex-direction:column;align-items:stretch;}
  .btn-primary,.btn-outline{text-align:center;padding:1rem 1.5rem;}
  .hero-stats{gap:1.5rem;}
  .stat-num{font-size:1.5rem;}

  section{padding:2.5rem 4%;}
  .section-title{margin-bottom:1.8rem;}

  .skills-grid{grid-template-columns:1fr;}
  .skill-card{padding:1.25rem;}

  .project-card{padding:1.5rem;}

  .contact-link{padding:0.85rem 1rem;}
  .contact-link-text span{font-size:0.62rem;}

  footer{flex-direction:column;text-align:center;padding:1.5rem 4%;}

  .contact-left h2{font-size:clamp(1.8rem,9vw,2.5rem);}
}

/* Very small — ≤ 360px */
@media(max-width:360px){
  .hero-name{font-size:1.7rem;}
  .hero-stats{flex-direction:column;gap:1rem;align-items:center;}
  nav{padding:0.9rem 3%;}
  section{padding:2rem 3%;}
}
</style>
